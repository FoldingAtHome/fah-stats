@require "./tokens.styl"

*, *::before, *::after
  box-sizing border-box

*
  scrollbar-width thin
  scrollbar-color $borderInput transparent

::-webkit-scrollbar
  width 8px
  height 8px
::-webkit-scrollbar-track
  background transparent
::-webkit-scrollbar-thumb
  background $borderInput
  border-radius 4px
::-webkit-scrollbar-thumb:hover
  background $borderHover

html, body
  margin 0
  padding 0
  background $bg
  color $fg
  font-family $fontStack
  font-size $fontSize
  line-height $lineHeight

h1, h2, h3, h4
  margin 0.6em 0 0.4em
  color $fg
  font-weight 600
h1
  font-size 1.6em
h2
  font-size 1.3em
h3
  font-size 1.1em

a
  color $accent
  text-decoration none
  &:hover
    color $accentHover
    text-decoration underline

button
  background $accent
  color #fff
  border 1px solid $accent
  padding $padTight $pad
  border-radius $radius
  cursor pointer
  font-family inherit
  font-size inherit
  display inline-flex
  align-items center
  gap 0.5em
  &:hover:not(:disabled)
    background $accentHover
    border-color $accentHover
  &:active:not(:disabled)
    background $accentDim
    border-color $accentDim
  &:disabled
    opacity 0.5
    cursor not-allowed
  &.ghost
    background transparent
    border-color transparent
    color $fgMuted
    &:hover:not(:disabled)
      background $bgHover
      border-color transparent
      color $fg

input, select, textarea
  background $bgRaised
  color $fg
  border 1px solid $borderInput
  border-radius $radius
  padding $padTight $pad
  font-family inherit
  font-size inherit
  &:focus
    outline none
    border-color $accent
  &::placeholder
    color $fgDim

table
  width 100%
  border-collapse collapse
  th, td
    text-align left
    padding $padTight $pad
    border-bottom 1px solid $border
  th
    background $bgRaised
    font-weight 600
    color $fgMuted

code, pre
  font-family $fontMono
  font-size 0.95em
::selection
  background $accentDim
  color #fff

:focus-visible
  outline 2px solid $accent
  outline-offset 2px

.message-page
  max-width 480px
  margin 4em auto
  text-align center
  h2
    color $fgMuted

// Leaderboard/list controls — shared by donors, teams, projects
.toolbar
  display flex
  flex-wrap wrap
  align-items center
  gap $gap
  margin 0 0 $pad
  .count
    color $fgMuted
    font-size 0.9em

.modes
  display inline-flex
  gap $padTight
  button
    background transparent
    border-color $borderInput
    color $fgMuted
    &.active
      background $accent
      border-color $accent
      color #fff

.search
  display inline-flex
  flex-wrap wrap
  gap $padTight

// Monthly rank-change indicator (leaderboards, minis)
.change
  font-weight 600
.change.new
  color $info
.change.up
  color $success
.change.down
  color $danger
.change.same
  color $fgDim

// Donor/team profile card — modeled on the original site
.profile-card
  position relative
  max-width 760px
  background $bgSurface
  border 1px solid $border
  border-radius $radiusLg
  overflow hidden
  .rank-badge
    position absolute
    top 0
    left 0
    z-index 2
    border-bottom-right-radius $radius
    &::after
      content ''
      position absolute
      top 100%
      left 0
      border-style solid
      border-width 0.35rem 0.35rem 0 0
      border-color rgba(0, 0, 0, 0.45) transparent transparent transparent
  .head
    display flex
    align-items center
    gap $pad
    padding $padLoose
    padding-top 2.2rem
    background $bgRaised
    border-bottom 1px solid $border
  .avatar
    flex none
    width 3rem
    height 3rem
    display inline-flex
    align-items center
    justify-content center
    color $accent
    svg
      width 3rem
      height 3rem
    .team-logo
      margin 0
    .team-logo img, .team-logo svg
      width 3rem
      height 3rem
  .title
    color $accent
    font-size 1.6rem
    font-weight 700
    margin 0
    a
      color $accent
  .rank
    color $fgMuted
    b
      color $fg
  .body
    padding $padLoose
    h3
      border-bottom 1px solid $border
      padding-bottom 0.3em
      margin-top $padLoose
    b
      color $fg
    .teams
      list-style none
      padding 0
      max-height 22rem
      overflow-y auto
      li
        margin-bottom $pad
      h4
        margin 0.2em 0
  .foot
    display flex
    flex-wrap wrap
    align-items center
    gap $padLoose
    padding $pad $padLoose
    border-top 1px solid $border
    .id
      color $fgMuted
  .error
    padding $padLoose
    color $danger

.team-logo
  display inline-flex
  vertical-align middle
  margin-right 0.4em
  img
    width 2rem
    height 2rem
    object-fit contain
    border-radius $radius
  svg
    width 1.6rem
    height 1.6rem
    color $fgMuted
