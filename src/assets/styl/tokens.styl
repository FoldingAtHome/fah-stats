// Design tokens. Color tokens alias CSS custom properties so the theme can be
// switched at runtime; the light/dark values live in base.styl (:root and
// [data-theme="dark"]). Non-color tokens stay literal. Imported globally via
// vite additionalData, so every <style lang="stylus"> block sees these.

$bgChrome    = var(--bgChrome)   // top header bar (dark in both themes)
$bg          = var(--bg)
$bgSurface   = var(--bgSurface)
$bgRaised    = var(--bgRaised)
$bgHover     = var(--bgHover)
$bgActive    = var(--bgActive)

$border      = var(--border)
$borderInput = var(--borderInput)
$borderHover = var(--borderHover)

$fg          = var(--fg)
$fgMuted     = var(--fgMuted)
$fgDim       = var(--fgDim)

// Header-bar text: always light, since the chrome bar is dark in both themes.
$chromeFg      = var(--chromeFg)
$chromeFgMuted = var(--chromeFgMuted)

$accent      = var(--accent)   // F@h orange
$accentHover = var(--accentHover)
$accentDim   = var(--accentDim)
$danger      = var(--danger)
$success     = var(--success)
$warning     = var(--warning)
$info        = var(--info)

$radius      = 4px
$radiusLg    = 8px
$padTight    = 0.4em
$pad         = 0.75em
$padLoose    = 1.5em
$gap         = 1em

$fontStack   = system-ui, -apple-system, "Segoe UI", Roboto, sans-serif
$fontMono    = ui-monospace, SFMono-Regular, Menlo, monospace
$fontDisplay = "Oswald", $fontStack       // headings / brand (from the old site)
$fontScript  = "SaintEliaRough", cursive   // the "your" in "Maximize your effort"
$fontSize    = 14px
$lineHeight  = 1.5

// Stats-site additions
$maxWidth    = 1100px   // centered content column
$bpMobile    = 700px    // breakpoint
